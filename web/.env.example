# Firebase Console → Project settings → Your apps → Web
# Vercel: Project → Settings → Environment Variables (NEXT_PUBLIC_* → Production + Preview)

NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Canlıya almadan önce Firebase Console ---
# Authentication → Sign-in method → Google → Etkinleştir
# Authentication → Settings → Authorized domains → your-app.vercel.app ve özel alan adınızı ekleyin
# Firestore Database → oluştur (üretim modu) → ardından: firebase deploy --only firestore:rules
# Storage → başlat → firebase deploy --only storage

# İsteğe bağlı: QR ve paylaşılan linkler için kanonik site adresi
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
